@{
    ViewData["Title"] = "Admin Login";
}

<style>
    body {
        margin: 0;
        padding: 0;
        height: 100vh;
        background: url('/images/login.png') no-repeat center center;
        background-size: cover;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 420px;
        padding: 40px;
        border-radius: 20px;
        background: rgba(80, 20, 60, 0.45);
        backdrop-filter: blur(10px);
        color: white;
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

    .logo-title {
        text-align: center;
        margin-bottom: 30px;
    }

        .logo-title h1 {
            font-size: 55px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .logo-title span {
            color: hotpink;
        }

    .login-title {
        text-align: center;
        font-size: 45px;
        font-weight: bold;
        margin-bottom: 30px;
    }

    .form-control {
        background: transparent;
        border: none;
        border-bottom: 2px solid white;
        border-radius: 0;
        color: white;
    }

        .form-control:focus {
            background: transparent;
            color: white;
            box-shadow: none;
            border-color: white;
        }

    .btn-login {
        width: 100%;
        border-radius: 30px;
        background: white;
        color: black;
        font-weight: bold;
        padding: 12px;
        border: none;
        margin-top: 20px;
    }

    label {
        margin-bottom: 5px;
    }

    #message {
        margin-top: 15px;
        text-align: center;
    }
</style>

<div class="login-card">

    <div class="logo-title">
        <h1>
            CART<span>NEST</span> 🛒
        </h1>
        <p>Admin Portal</p>
    </div>

    <div class="login-title">
        Login
    </div>

    <div class="mb-4">
        <label>Username</label>
        <input id="username"
               type="text"
               class="form-control"
               placeholder="Enter Username" />
    </div>

    <div class="mb-4">
        <label>Password</label>
        <input id="password"
               type="password"
               class="form-control"
               placeholder="Enter Password" />
    </div>

    <button id="btnLogin"
            class="btn-login">
        Login
    </button>

    <div id="message"></div>

</div>

<script src="~/js/login.js"></script>