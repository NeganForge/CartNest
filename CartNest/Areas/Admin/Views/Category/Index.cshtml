@model IEnumerable<CartNest.Models.Entities.Category>

<h2>Category List</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Add Category
    </a>
</p>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th width="180">Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>
                <td>@item.Name</td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>