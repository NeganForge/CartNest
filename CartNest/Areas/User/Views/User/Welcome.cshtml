@{
    ViewData["Title"] = "Dashboard";
}

<style>

    body {
        background: linear-gradient(135deg,#FFF6F9,#FFEAF2);
        font-family: 'Segoe UI',sans-serif;
    }

    .main-container {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 12px 35px rgba(255,79,139,.18);
    }

    /* ---------- NAVBAR ---------- */

    .navbar-cartnest {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .logo {
        font-size: 40px;
        font-weight: bold;
        color: #222;
    }

        .logo span {
            color: #FF4F8B;
        }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .nav-btn {
        background: #FFF8FB;
        border: 1px solid #FFD6E5;
        border-radius: 12px;
        padding: 10px 18px;
        transition: .3s;
    }

        .nav-btn:hover {
            background: #FFE8F0;
        }

    .dropdown-menu {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(255,79,139,.18);
    }

    .dropdown-item:hover {
        background: #FFE8F0;
        color: #FF4F8B;
    }

    /* ---------- SEARCH ---------- */

    .tagline {
        text-align: center;
        color: #666;
        margin-bottom: 30px;
        font-size: 18px;
    }

    .form-control {
        height: 52px;
        border: 2px solid #FFD6E5;
        border-radius: 12px;
    }

        .form-control:focus {
            border-color: #FF4F8B;
            box-shadow: 0 0 10px rgba(255,79,139,.2);
        }

    .btn-search {
        background: #FF4F8B;
        color: white;
        border: none;
        padding: 0 30px;
        border-radius: 12px;
    }

        .btn-search:hover {
            background: #FF2F74;
            color: white;
        }

    /* ---------- CATEGORY ---------- */

    h3 {
        color: #FF4F8B;
        font-weight: bold;
    }

    .category-card {
        background: #FFF8FB;
        border: 1px solid #FFD6E5;
        border-radius: 18px;
        padding: 30px;
        text-align: center;
        transition: .3s;
        cursor: pointer;
        height: 100%;
    }

        .category-card:hover {
            background: #FFE8F0;
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(255,79,139,.18);
        }

    .emoji {
        font-size: 40px;
        margin-bottom: 10px;
    }

    .category-title {
        font-weight: 600;
        font-size: 18px;
    }

    .search-card {
        transition: .25s;
    }

        .search-card:hover {
            background: #FFF5F9;
            border: 1px solid #FF4F8B;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255,79,139,.15);
        }

</style>

<div class="container py-5">

    <div class="main-container">

        <div class="navbar-cartnest">

            <div class="logo">
                CART<span>NEST</span> 🛒 DEVOPS DEPLOYED 
            </div>

            <div class="nav-right">

                <button class="btn nav-btn">
                    ❤️ Wishlist
                </button>

                <a asp-area="User"
                   asp-controller="Cart"
                   asp-action="Index"
                   class="btn nav-btn">
                    🛒 Cart
                </a>

                <div class="dropdown">

                    <button class="btn btn-search dropdown-toggle"
                            data-bs-toggle="dropdown">

                        👤 My Account

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <a class="dropdown-item" href="#">
                                👤 My Profile
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-area="User"
                               asp-controller="Settings"
                               asp-action="MyOrders">
                                📦 My Orders
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                ❤️ Wishlist
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">
                                📍 My Address
                            </a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a asp-area="User"
                               asp-controller="Settings"
                               asp-action="Settings"
                               class="dropdown-item">

                                ⚙️ Settings

                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item text-danger" href="#">
                                🚪 Logout
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <div class="tagline">

            Shop Smarter. Live Better.

        </div>

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="input-group">

                    <input type="text"
                           id="searchBox"
                           class="form-control"
                           placeholder="Search Products..." />

                    <button class="btn btn-search"
                            id="searchBtn">

                        Search

                    </button>

                </div>

                <div id="searchResults"
                     class="mt-3">
                </div>

            </div>

        </div>

        <h3 class="mt-5 mb-4">

            Shop by Categories

        </h3>

        <div class="row g-4">
            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        📱
                    </div>

                    <div class="category-title">
                        Electronics
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        👕
                    </div>

                    <div class="category-title">
                        Fashion
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        💻
                    </div>

                    <div class="category-title">
                        Computers
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        🎮
                    </div>

                    <div class="category-title">
                        Gaming
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        📚
                    </div>

                    <div class="category-title">
                        Books
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        🏠
                    </div>

                    <div class="category-title">
                        Home
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        🧸
                    </div>

                    <div class="category-title">
                        Toys
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        💄
                    </div>

                    <div class="category-title">
                        Beauty
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        ⌚
                    </div>

                    <div class="category-title">
                        Accessories
                    </div>

                </div>

            </div>

            <div class="col-md-4 col-lg-2">

                <div class="category-card">

                    <div class="emoji">
                        ⚽
                    </div>

                    <div class="category-title">
                        Sports
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script src="~/js/Search.js"></script>
}
