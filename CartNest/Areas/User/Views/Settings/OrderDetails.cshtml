@model CartNest.Models.Entities.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-4">

    <h2>Order Details</h2>
    <hr />

    <div class="mb-4">
        <p><strong>Order ID:</strong> @Model.Id</p>
        <p><strong>Order Date:</strong> @Model.OrderDate.ToString("dd MMM yyyy")</p>
        
        <p><strong>Total Amount:</strong> ₹@Model.TotalAmount</p>
    </div>

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.OrderItems)
            {
                <tr>
                    <td>
                        <img src="@item.Product.ImageUrl"
                             width="80"
                             height="80"
                             class="rounded" />
                    </td>

                    <td>@item.Product.Name</td>

                    <td>₹@item.Product.Price</td>

                    <td>@item.Quantity</td>

                    <td>₹@(item.Product.Price * item.Quantity)</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="MyOrders" class="btn btn-secondary">
        Back
    </a>

</div>