@{
    ViewData["Title"] = "Reset Password";
}

<style>

    body {
        background: linear-gradient(135deg,#FFF6F9,#FFEAF2);
        font-family: "Segoe UI", sans-serif;
    }

    .reset-card {
        max-width: 550px;
        margin: 70px auto;
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 12px 35px rgba(255,79,139,.18);
    }

    .title {
        text-align: center;
        color: #FF4F8B;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .subtitle {
        text-align: center;
        color: #666;
        margin-bottom: 35px;
    }

    .form-label {
        font-weight: 600;
    }

    .input-group-text {
        background: white;
        border: 2px solid #FFD6E5;
        border-left: none;
        cursor: pointer;
    }

    .form-control {
        border: 2px solid #FFD6E5;
        border-right: none;
        height: 52px;
    }

        .form-control:focus {
            border-color: #FF4F8B;
            box-shadow: none;
        }

    .btn-cartnest {
        background: #FF4F8B;
        color: white;
        border: none;
        border-radius: 12px;
        height: 50px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-cartnest:hover {
            background: #FF2D73;
            color: white;
        }

</style>

<div class="container">

    <div class="reset-card">

        <h2 class="title">

            🔑 Reset Password

        </h2>

        <p class="subtitle">

            Create a new secure password for your CartNest account.

        </p>

        <div class="mb-4">

            <label class="form-label">

                New Password

            </label>

            <div class="input-group">

                <input type="password"
                       id="newPassword"
                       class="form-control"
                       placeholder="Enter New Password">

                <span class="input-group-text"
                      onclick="togglePassword('newPassword',this)">

                    👁️

                </span>

            </div>

        </div>

        <div class="mb-4">

            <label class="form-label">

                Confirm Password

            </label>

            <div class="input-group">

                <input type="password"
                       id="confirmPassword"
                       class="form-control"
                       placeholder="Confirm Password">

                <span class="input-group-text"
                      onclick="togglePassword('confirmPassword',this)">

                    👁️

                </span>

            </div>

        </div>

        <button class="btn btn-cartnest w-100"
                onclick="updatePassword()">

            Update Password

        </button>

        <div id="result"
             class="text-center mt-3 fw-bold text-danger">
        </div>

    </div>

</div>

@section Scripts
{

    <script>

        function togglePassword(id,icon)
        {
            const input=document.getElementById(id);

            if(input.type==="password")
            {
                input.type="text";
                icon.innerHTML="🙈";
            }
            else
            {
                input.type="password";
                icon.innerHTML="👁️";
            }
        }

        function updatePassword()
        {
            const newPassword=document.getElementById("newPassword").value;
            const confirmPassword=document.getElementById("confirmPassword").value;

            if(newPassword==="" || confirmPassword==="")
            {
                document.getElementById("result").innerHTML="Please fill all fields.";
                return;
            }

            if(newPassword!==confirmPassword)
            {
                document.getElementById("result").innerHTML="Passwords do not match.";
                return;
            }

            // TODO:
            // Call Controller
            // Update Password
            // Redirect Login

            document.getElementById("result").innerHTML="Ready to update password.";

        }

    </script>

}